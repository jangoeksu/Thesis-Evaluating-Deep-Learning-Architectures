# Python cache files
__pycache__/
*.py[cod]
*$py.class

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment and secret files
.env
.env.*
*.env

# Operating system files
.DS_Store
Thumbs.db

# Editor and IDE folders
.vscode/
.idea/

# Raw datasets stored locally only
data/raw/*
!data/raw/.gitkeep
!data/raw/raw_data_metadata.json

# Processed datasets generated by src/data.py
data/processed/*
!data/processed/.gitkeep

# Trained models, vocabularies, tokenizer files, and checkpoints
models/*
!models/.gitkeep

# Generated runtime logs
results/logs/

# Optional temporary files
*.tmp
*.log
